const BASE = "http://localhost:3000";
let token = "";

async function main() {
  const lr = await fetch(BASE + "/api/auth/login", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ username: "fulltest", password: "testpass123" }),
  });
  const cookie = lr.headers.get("set-cookie");
  const match = cookie.match(/auth-token=([^;]+)/);
  token = match[1];

  const lu = await fetch(BASE + "/api/universes", { headers: { Cookie: `auth-token=${token}` } });
  const ld = await lu.json();
  const ub = ld.universes.find((u: any) => u.name === "Universe B");
  console.log("Universe B:", ub?.id);

  const dr = await fetch(BASE + "/api/universes/" + ub.id, {
    method: "DELETE",
    headers: { Cookie: `auth-token=${token}` },
  });
  console.log("Delete status:", dr.status);
  console.log("Delete body:", await dr.text());
}

main().catch(console.error);
