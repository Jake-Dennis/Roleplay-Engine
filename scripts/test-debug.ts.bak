const BASE = "http://localhost:3000";
let token = "";

async function api(method, path, body) {
  const opts = { method, headers: { "Content-Type": "application/json", Cookie: `auth-token=${token}` } };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(BASE + path, opts);
  return { status: res.status, data: await res.json() };
}

async function main() {
  // Login
  const lr = await fetch(BASE + "/api/auth/login", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ username: "fulltest", password: "testpass123" }),
  });
  const cookie = lr.headers.get("set-cookie");
  const match = cookie.match(/auth-token=([^;]+)/);
  token = match[1];

  // Test queue-idle
  const qi = await api("POST", "/api/jobs", { action: "queue-idle", universe_id: "814457d9-e8c2-4c5e-8a06-5932f639e41b" });
  console.log("queue-idle status:", qi.status);
  console.log("queue-idle data:", JSON.stringify(qi.data));

  // Test get settings
  const gs = await api("GET", "/api/settings");
  console.log("get settings status:", gs.status);
  console.log("get settings data:", JSON.stringify(gs.data));

  // Test delete universe B
  const du = await api("DELETE", "/api/universes/d0f9aee1-cf7f-42da-92c3-55e48eb879c4");
  console.log("delete universe status:", du.status);
  console.log("delete universe data:", JSON.stringify(du.data));

  // List universes
  const lu = await api("GET", "/api/universes");
  console.log("list universes:", JSON.stringify(lu.data.universes?.map(u => ({ id: u.id.slice(0,8), name: u.name }))));
}

main().catch(console.error);
