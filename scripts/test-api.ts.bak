const BASE = "http://localhost:3000";

async function main() {
  // Register
  const r1 = await fetch(BASE + "/api/auth/register", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ username: "testuser4", password: "testpass123" }),
  });
  console.log("Register status:", r1.status);
  const d1 = await r1.json();
  console.log("Register body:", JSON.stringify(d1));

  // Login
  const r2 = await fetch(BASE + "/api/auth/login", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ username: "testuser4", password: "testpass123" }),
  });
  console.log("Login status:", r2.status);
  const d2 = await r2.json();
  console.log("Login body:", JSON.stringify(d2));
  const setCookie = r2.headers.get("set-cookie");
  console.log("Set-Cookie header:", setCookie?.slice(0, 50) + "...");
  const tokenMatch = setCookie?.match(/auth-token=([^;]+)/);
  const token = tokenMatch ? tokenMatch[1] : null;

  if (!token) {
    console.log("No token, exiting");
    return;
  }

  // Create universe
  const r3 = await fetch(BASE + "/api/universes", {
    method: "POST",
    headers: { "Content-Type": "application/json", Cookie: `auth-token=${token}` },
    body: JSON.stringify({ name: "Test Universe", tone: "fantasy" }),
  });
  console.log("Create universe status:", r3.status);
  const d3 = await r3.json();
  console.log("Create universe body:", JSON.stringify(d3));
  const universeId = d3.universe?.id;

  if (!universeId) {
    console.log("No universe ID, exiting");
    return;
  }

  // Create location in universe
  const r4 = await fetch(BASE + "/api/locations", {
    method: "POST",
    headers: { "Content-Type": "application/json", Cookie: `auth-token=${token}` },
    body: JSON.stringify({ name: "Test Location", importance: "high", universe_id: universeId }),
  });
  console.log("Create location status:", r4.status);
  const d4 = await r4.json();
  console.log("Create location body:", JSON.stringify(d4));

  // List locations scoped to universe
  const r5 = await fetch(BASE + `/api/locations?universe_id=${universeId}`, {
    headers: { Cookie: `auth-token=${token}` },
  });
  console.log("List locations status:", r5.status);
  const d5 = await r5.json();
  console.log("List locations count:", d5.locations?.length);
  console.log("List locations:", JSON.stringify(d5.locations));

  // List locations without universe filter (should show all)
  const r6 = await fetch(BASE + "/api/locations", {
    headers: { Cookie: `auth-token=${token}` },
  });
  console.log("List all locations count:", (await r6.json()).locations?.length);

  // Queue a job
  const r7 = await fetch(BASE + "/api/jobs", {
    method: "POST",
    headers: { "Content-Type": "application/json", Cookie: `auth-token=${token}` },
    body: JSON.stringify({ action: "queue", type: "summarize_messages", payload: { sessionId: "fake" }, priority: "low", universe_id: universeId }),
  });
  console.log("Queue job status:", r7.status);
  const d7 = await r7.json();
  console.log("Queue job body:", JSON.stringify(d7));

  // Get jobs scoped to universe
  const r8 = await fetch(BASE + `/api/jobs?universe_id=${universeId}`, {
    headers: { Cookie: `auth-token=${token}` },
  });
  console.log("List jobs status:", r8.status);
  const d8 = await r8.json();
  console.log("List jobs count:", d8.jobs?.length);

  // Get jobs without universe filter
  const r9 = await fetch(BASE + "/api/jobs", {
    headers: { Cookie: `auth-token=${token}` },
  });
  console.log("List all jobs count:", (await r9.json()).jobs?.length);

  // Idle heartbeat
  const r10 = await fetch(BASE + "/api/idle/heartbeat", {
    method: "POST",
    headers: { "Content-Type": "application/json", Cookie: `auth-token=${token}` },
    body: JSON.stringify({ idleTime: 300000, tier: 1, page: "/dashboard", universeId: universeId }),
  });
  console.log("Heartbeat status:", r10.status);
  const d10 = await r10.json();
  console.log("Heartbeat body:", JSON.stringify(d10));

  console.log("\n=== All API calls completed ===");
}

main().catch(console.error);
