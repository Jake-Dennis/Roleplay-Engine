# =============================================================================
# Roleplay-Engine — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# JWT secret for signing and verifying authentication tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required — no default value.
JWT_SECRET=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Server port (default: 3000)
PORT=3000

# ---------------------------------------------------------------------------
# Ollama (Self-Hosted LLM)
# ---------------------------------------------------------------------------

# Ollama host address (default: 192.168.6.1)
OLLAMA_HOST=192.168.6.1

# Ollama port (default: 11434)
OLLAMA_PORT=11434

# LLM model name (default: qwen3.5:9B)
OLLAMA_MODEL=qwen3.5:9B

# Embedding model name (default: bge-m3)
OLLAMA_EMBEDDING_MODEL=bge-m3


# ---------------------------------------------------------------------------
# Text-to-Speech (Kokoro TTS)
# ---------------------------------------------------------------------------

# Kokoro TTS host address (default: 192.168.4.2)
TTS_HOST=192.168.4.2

# Kokoro TTS port (default: 8880)
TTS_PORT=8880

# ---------------------------------------------------------------------------
# Data Storage
# ---------------------------------------------------------------------------

# Directory for runtime data (SQLite databases, wiki markdown files).
# Defaults to ./data relative to project root.
# DATA_DIR=./data

# ---------------------------------------------------------------------------
# Wiki
# ---------------------------------------------------------------------------

# Maximum characters per wiki page before suggesting a split.
# Default: 10000 (10k characters) — warning banner at 80%.
# WIKI_MAX_PAGE_SIZE=10000
